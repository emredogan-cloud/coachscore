# =============================================================================
# CoachScore — Environment Variables (template)
# =============================================================================
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Each variable is annotated with the PHASE that first requires it, so the
# build can proceed incrementally and gate cleanly on missing credentials.
# -----------------------------------------------------------------------------

# --- App (Phase 0) ----------------------------------------------------------
# Canonical/sitemap/OG/JSON-LD all derive from this — it MUST be the production
# origin (no trailing slash). Override to http://localhost:3000 in .env.local
# for local dev. (Roadmap §9.1: a localhost value here breaks indexing.)
NEXT_PUBLIC_APP_URL="https://coachscore.app"
NEXT_PUBLIC_APP_ENV="development"   # development | preview | production
# Optional: real, verified profile URLs for Organization sameAs (comma-sep).
# Leave empty until the profiles actually exist — never fabricate (roadmap §11).
NEXT_PUBLIC_SOCIAL_PROFILES=""

# --- AI pipeline — Anthropic Claude (Phase 2) -------------------------------
# Opus for diagnosis/roadmap reasoning; Haiku for screenshot OCR/extraction.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL_REASONING="claude-opus-4-8"
ANTHROPIC_MODEL_EXTRACTION="claude-haiku-4-5-20251001"

# --- Image asset generation — OpenAI (BUILD-TIME TOOLING ONLY) --------------
# NOT read by the app at runtime. Used only by the premium-asset generation
# script (gpt-image-1). Standard name is OPENAI_API_KEY (no trailing space).
OPENAI_API_KEY=""

# --- Database / Auth / Storage — Supabase (Phase 3+) ------------------------
# NOTE: the SUPABASE_* keys below are consumed ONLY when Supabase Auth/client is
# wired (currently the app uses an anon identity stub and persists via
# DATABASE_URL). They are unused by the runtime today — wire Auth or omit them.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""        # server-only; never exposed to the client
# Postgres connection string (Drizzle). For serverless/edge deploys use the
# Supabase POOLER host (aws-0-<region>.pooler.supabase.com:6543), not the direct
# db.<ref>.supabase.co host, which may be IPv6-only / unroutable from some envs.
DATABASE_URL=""

# --- Object storage — Cloudflare R2 (Phase 3+) ------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="coachscore-media"

# --- Payments — LemonSqueezy (RECOMMENDED, Merchant of Record) --------------
# See PAYMENTS_DECISION_RECORD.md. LemonSqueezy is the recommended customer-
# billing provider: it is a Merchant of Record (handles global VAT/sales-tax,
# invoices/receipts, refunds, fraud) and has built-in affiliates + signed
# webhooks — the right fit for one-time digital reports sold globally by a solo
# operator. Map one variant per purchasable SKU.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_VARIANT_STANDARD=""        # main full report
LEMONSQUEEZY_VARIANT_REPLAY_DOCTOR=""   # ReplayDoctor SKU
LEMONSQUEEZY_VARIANT_BASE_DOCTOR=""      # BaseDoctor SKU
LEMONSQUEEZY_VARIANT_WAR_PLAN=""         # WarPlan SKU

# --- Payments — Stripe (LEGACY / optional; superseded by LemonSqueezy) ------
# Kept only if you choose Stripe over LemonSqueezy (not recommended — see PDR).
# STRIPE_CONNECT_CLIENT_ID stays relevant ONLY for coach marketplace PAYOUTS,
# which are a separate rail (Stripe Connect / Wise / Payoneer) from customer
# billing — LemonSqueezy does not do third-party payouts.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_CONNECT_CLIENT_ID=""          # coach payouts only (marketplace)

# --- Analytics / Experiments — PostHog + Plausible (Phase 7) ----------------
# All optional. Absent ⇒ analytics forwards to a no-op sink and (with
# DATABASE_URL) persists locally to power the growth dashboard. Experiment
# assignment is deterministic and needs no key.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# --- Email — Resend (Phase 4) -----------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CoachScore <noreply@coachscore.app>"  # verified sender

# --- Clash of Clans API via fixed-IP compliant proxy (optional intake path) -
# Public data only. One of THREE intake paths — never the sole dependency.
COC_API_TOKEN=""
COC_API_PROXY_URL=""

# --- Observability — Sentry + uptime + logging (Phase 9, all optional) ------
# Absent ⇒ errors log via the structured logger; heartbeat is a no-op.
SENTRY_DSN=""
BETTERSTACK_HEARTBEAT_URL=""
LOG_LEVEL="info"  # debug | info | warn | error
