{
  "name": "coachscore",
  "version": "0.1.0",
  "private": true,
  "description": "CoachScore — productized 'rate my account + upgrade roadmap' for Clash of Clans. AI-drafted, human-verified, one-time coaching reports.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "validate:reference": "tsx scripts/validate-reference-table.ts",
    "validate:seo": "tsx scripts/validate-seo.ts",
    "assets:generate": "tsx scripts/generate-premium-assets.ts",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.19",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
