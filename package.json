{
  "name": "coachscore",
  "version": "0.1.0",
  "private": true,
  "description": "CoachScore — productized 'rate my account + upgrade roadmap' for Clash of Clans. AI-drafted, human-verified, one-time coaching reports.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "validate:reference": "tsx scripts/validate-reference-table.ts",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@next/eslint-plugin-next": "^15.5.19",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
